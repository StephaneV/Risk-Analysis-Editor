{
  "format": "risk-analysis-editor",
  "version": "1.0",
  "metadata": {
    "title": "EBIOS RM template (ANSSI)",
    "description": "Analysis skeleton following **EBIOS Risk Manager** (ANSSI). Likelihood × severity grid, risk levels and custom fields preconfigured.\n\nTo complete: business values and supporting assets (workshop 1), risk sources and target objectives (workshop 2), strategic scenarios (workshop 3) then operational ones (workshop 4), and treatment (workshop 5).",
    "author": "",
    "organization": "",
    "scope": "",
    "methodology_reference": "EBIOS Risk Manager (ANSSI)",
    "revision": "1.0",
    "status": "draft",
    "language": "en",
    "kind": "template"
  },
  "grid": {
    "vertical_axis": {
      "label": "Likelihood",
      "description": "Possibility that the scenario occurs, given risk sources and modes of operation.",
      "levels": [
        {
          "value": 1,
          "label": "Minimal",
          "description": "The risk source is unlikely to act, or the mode of operation is very hard to carry out."
        },
        {
          "value": 2,
          "label": "Significant",
          "description": "The risk source could act; the mode of operation remains feasible with moderate effort."
        },
        {
          "value": 3,
          "label": "Strong",
          "description": "The risk source has good reasons to act and the mode of operation is accessible."
        },
        {
          "value": 4,
          "label": "Maximum",
          "description": "The risk source will very likely act; the mode of operation is trivial."
        }
      ]
    },
    "horizontal_axis": {
      "label": "Severity",
      "description": "Extent of consequences for the organisation and people.",
      "levels": [
        {
          "value": 1,
          "label": "Minor",
          "description": "No notable operational or legal impact; a surmountable nuisance."
        },
        {
          "value": 2,
          "label": "Significant",
          "description": "Real but manageable impact, with no lasting consequence."
        },
        {
          "value": 3,
          "label": "Serious",
          "description": "Major impact on operations or people, hard to reverse."
        },
        {
          "value": 4,
          "label": "Critical",
          "description": "Major, potentially irreversible impact threatening viability or safety."
        }
      ]
    },
    "score": {
      "method": "product"
    },
    "criticality_levels": [
      {
        "code": "faible",
        "label": "Low",
        "score_min": 1,
        "score_max": 3,
        "color": "#2e9e5b",
        "acceptance": "acceptable",
        "order": 1,
        "description": "Low risk: acceptable as is, to be monitored during reviews."
      },
      {
        "code": "modere",
        "label": "Moderate",
        "score_min": 4,
        "score_max": 6,
        "color": "#e0b93a",
        "acceptance": "tolerable",
        "order": 2,
        "description": "Moderate risk: tolerable under conditions; reduction measures should be considered."
      },
      {
        "code": "eleve",
        "label": "High",
        "score_min": 7,
        "score_max": 11,
        "color": "#e6862e",
        "acceptance": "to_treat",
        "order": 3,
        "description": "High risk: treatment is expected to bring the risk to an acceptable level."
      },
      {
        "code": "critique",
        "label": "Critical",
        "score_min": 12,
        "score_max": 16,
        "color": "#d64545",
        "acceptance": "unacceptable",
        "order": 4,
        "description": "Critical risk: unacceptable as is; priority treatment required."
      }
    ]
  },
