{
  "format": "risk-analysis-editor",
  "version": "1.0",
  "metadata": {
    "title": "Modello EBIOS RM (ANSSI)",
    "description": "Scheletro di analisi secondo **EBIOS Risk Manager** (ANSSI). Griglia verosimiglianza × gravità, livelli di rischio e campi personalizzati preconfigurati.\n\nDa completare: valori di business e beni di supporto (workshop 1), fonti di rischio e obiettivi (workshop 2), scenari strategici (workshop 3) e operativi (workshop 4), e il trattamento (workshop 5).",
    "author": "",
    "organization": "",
    "scope": "",
    "methodology_reference": "EBIOS Risk Manager (ANSSI)",
    "revision": "1.0",
    "status": "draft",
    "language": "it",
    "kind": "template"
  },
  "grid": {
    "vertical_axis": {
      "label": "Verosimiglianza",
      "description": "Possibilità che lo scenario si verifichi, viste le fonti di rischio e i modi operativi.",
      "levels": [
        {
          "value": 1,
          "label": "Minima",
          "description": "È improbabile che la fonte di rischio agisca, o il modo operativo è molto difficile da attuare."
        },
        {
          "value": 2,
          "label": "Significativa",
          "description": "La fonte di rischio potrebbe agire; il modo operativo resta realizzabile con uno sforzo moderato."
        },
        {
          "value": 3,
          "label": "Forte",
          "description": "La fonte di rischio ha buoni motivi per agire e il modo operativo è accessibile."
        },
        {
          "value": 4,
          "label": "Massima",
          "description": "La fonte di rischio agirà molto probabilmente; il modo operativo è banale."
        }
      ]
    },
    "horizontal_axis": {
      "label": "Gravità",
      "description": "Entità delle conseguenze per l'organizzazione e le persone.",
      "levels": [
        {
          "value": 1,
          "label": "Minore",
          "description": "Nessun impatto operativo o giuridico rilevante; disagio superabile."
        },
        {
          "value": 2,
          "label": "Significativa",
          "description": "Impatto reale ma gestibile, senza conseguenze durature."
        },
        {
          "value": 3,
          "label": "Grave",
          "description": "Impatto importante, difficilmente reversibile, su attività o persone."
        },
        {
          "value": 4,
          "label": "Critica",
          "description": "Impatto grave, potenzialmente irreversibile, che mette a rischio la continuità o la sicurezza."
        }
      ]
    },
    "score": {
      "method": "product"
    },
    "criticality_levels": [
      {
        "code": "faible",
        "label": "Basso",
        "score_min": 1,
        "score_max": 3,
        "color": "#2e9e5b",
        "acceptance": "acceptable",
        "order": 1,
        "description": "Rischio basso: accettabile così com'è, da monitorare nelle revisioni."
      },
      {
        "code": "modere",
        "label": "Moderato",
        "score_min": 4,
        "score_max": 6,
        "color": "#e0b93a",
        "acceptance": "tolerable",
        "order": 2,
        "description": "Rischio moderato: tollerabile a condizioni; valutare misure di riduzione."
      },
      {
        "code": "eleve",
        "label": "Elevato",
        "score_min": 7,
        "score_max": 11,
        "color": "#e6862e",
        "acceptance": "to_treat",
        "order": 3,
        "description": "Rischio elevato: è previsto un trattamento per riportare il rischio a un livello accettabile."
      },
      {
        "code": "critique",
        "label": "Critico",
        "score_min": 12,
        "score_max": 16,
        "color": "#d64545",
        "acceptance": "unacceptable",
        "order": 4,
        "description": "Rischio critico: inaccettabile così com'è; trattamento prioritario richiesto."
      }
    ]
  },
