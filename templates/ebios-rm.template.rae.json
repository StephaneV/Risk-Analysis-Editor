{
  "format": "risk-analysis-editor",
  "version": "1.0",
  "metadata": {
    "author": "",
    "organization": "",
    "scope": "",
    "revision": "1.0",
    "status": "draft",
    "language": "fr",
    "kind": "template",
    "title": "Modèle EBIOS RM (ANSSI)",
    "description": "Squelette d'analyse selon **EBIOS Risk Manager** (ANSSI). Grille de vraisemblance × gravité, niveaux de risque et champs personnalisés préconfigurés.\n\nÀ compléter : valeurs métier et biens supports (atelier 1), sources de risque et objectifs visés (atelier 2), scénarios stratégiques (atelier 3) puis opérationnels (atelier 4), et le traitement (atelier 5).",
    "methodology_reference": "EBIOS Risk Manager (ANSSI)"
  },
  "grid": {
    "vertical_axis": {
      "label": "Vraisemblance",
      "description": "Possibilité que le scénario se réalise, au regard des sources de risque et des modes opératoires.",
      "levels": [
        {
          "value": 1,
          "label": "Minime",
          "description": "La source de risque ne devrait pas agir, ou le mode opératoire est très difficile à mettre en œuvre."
        },
        {
          "value": 2,
          "label": "Significative",
          "description": "La source de risque pourrait agir ; le mode opératoire reste réalisable avec un effort modéré."
        },
        {
          "value": 3,
          "label": "Forte",
          "description": "La source de risque a de bonnes raisons d'agir et le mode opératoire est accessible."
        },
        {
          "value": 4,
          "label": "Maximale",
          "description": "La source de risque va très probablement agir ; le mode opératoire est trivial."
        }
      ]
    },
    "horizontal_axis": {
      "label": "Gravité",
      "description": "Ampleur des conséquences pour l'organisation et les personnes.",
      "levels": [
        {
          "value": 1,
          "label": "Mineure",
          "description": "Aucun impact opérationnel ou juridique notable ; gêne surmontable."
        },
        {
          "value": 2,
          "label": "Significative",
          "description": "Impact réel mais maîtrisable, sans conséquence durable."
        },
        {
          "value": 3,
          "label": "Grave",
          "description": "Impact important, difficilement réversible, sur l'activité ou les personnes."
        },
        {
          "value": 4,
          "label": "Critique",
          "description": "Impact majeur, potentiellement irréversible, mettant en cause la pérennité ou la sécurité."
        }
      ]
    },
    "score": {
      "method": "product"
    },
    "criticality_levels": [
      {
        "code": "faible",
        "label": "Faible",
        "score_min": 1,
        "score_max": 3,
        "color": "#2e9e5b",
        "acceptance": "acceptable",
        "order": 1,
        "description": "Risque faible : acceptable en l'état, à surveiller lors des revues."
      },
      {
        "code": "modere",
        "label": "Modéré",
        "score_min": 4,
        "score_max": 6,
        "color": "#e0b93a",
        "acceptance": "tolerable",
        "order": 2,
        "description": "Risque modéré : tolérable sous conditions ; des mesures de réduction sont à envisager."
      },
      {
        "code": "eleve",
        "label": "Élevé",
        "score_min": 7,
        "score_max": 11,
        "color": "#e6862e",
        "acceptance": "to_treat",
        "order": 3,
        "description": "Risque élevé : un traitement est attendu pour ramener le risque à un niveau acceptable."
      },
      {
        "code": "critique",
        "label": "Critique",
        "score_min": 12,
        "score_max": 16,
        "color": "#d64545",
        "acceptance": "unacceptable",
        "order": 4,
        "description": "Risque critique : inacceptable en l'état ; traitement prioritaire requis."
      }
    ]
  },
