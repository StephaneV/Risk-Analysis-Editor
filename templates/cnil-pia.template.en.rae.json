{
  "format": "risk-analysis-editor",
  "version": "1.0",
  "metadata": {
    "title": "DPIA template — CNIL PIA",
    "description": "**Data Protection Impact Assessment** skeleton following the **CNIL PIA** method. Four-level grid whose risk level is defined **per cell** (not by product), with custom fields specific to the approach.\n\nTo complete: context and processors, then for each feared event (illegitimate access, unwanted modification, unavailability) the scenarios, their initial and residual rating, and the action plan.",
    "author": "",
    "organization": "",
    "scope": "",
    "methodology_reference": "CNIL PIA method (Privacy Impact Assessment)",
    "revision": "1.0",
    "status": "draft",
    "language": "en",
    "kind": "template"
  },
  "grid": {
    "vertical_axis": {
      "label": "Likelihood",
      "description": "Possibility that a risk occurs, given asset vulnerabilities and risk sources.",
      "levels": [
        {
          "value": 1,
          "label": "Negligible",
          "description": "It does not seem possible for the threat to occur."
        },
        {
          "value": 2,
          "label": "Limited",
          "description": "It seems difficult for risk sources to carry out the threat."
        },
        {
          "value": 3,
          "label": "Significant",
          "description": "It seems possible for risk sources to carry out the threat."
        },
        {
          "value": 4,
          "label": "Maximum",
          "description": "It seems extremely easy for risk sources to carry out the threat."
        }
      ]
    },
    "horizontal_axis": {
      "label": "Severity",
      "description": "Extent of the risk, assessed against potential impacts on data subjects.",
      "levels": [
        {
          "value": 1,
          "label": "Negligible",
          "description": "Data subjects will not be affected or will overcome minor inconveniences without difficulty."
        },
        {
          "value": 2,
          "label": "Limited",
          "description": "Data subjects may face significant inconveniences, surmountable despite difficulties."
        },
        {
          "value": 3,
          "label": "Significant",
          "description": "Data subjects may face significant consequences, surmountable but with real difficulties."
        },
        {
          "value": 4,
          "label": "Maximum",
          "description": "Data subjects may face significant, even irreversible consequences they might not overcome."
        }
      ]
    },
    "score": {
      "method": "matrix",
      "matrix": [
        [
          1,
          1,
          2,
          3
        ],
        [
          1,
          2,
          2,
          3
        ],
        [
          2,
          2,
          3,
          4
        ],
        [
          3,
          3,
          4,
          4
        ]
      ]
    },
    "criticality_levels": [
      {
        "code": "negligeable",
        "label": "Negligible",
        "score_min": 1,
        "score_max": 1,
        "color": "#8CC63E",
        "acceptance": "acceptable",
        "order": 1,
        "description": "Negligible risk level per the PIA method."
      },
      {
        "code": "limite",
        "label": "Limited",
        "score_min": 2,
        "score_max": 2,
        "color": "#FFF166",
        "acceptance": "acceptable",
        "order": 2,
        "description": "Limited risk level per the PIA method."
      },
      {
        "code": "important",
        "label": "Significant",
        "score_min": 3,
        "score_max": 3,
        "color": "#F2B33D",
        "acceptance": "tolerable",
        "order": 3,
        "description": "Significant risk level: reduction measures are expected."
      },
      {
        "code": "maximal",
        "label": "Maximum",
        "score_min": 4,
        "score_max": 4,
        "color": "#E8291C",
        "acceptance": "unacceptable",
        "order": 4,
        "description": "Maximum risk level: the processing cannot be carried out as is."
      }
    ]
  },
  "custom_fields": [
    {
      "code": "responsable_traitement",
      "target": "analysis",
      "type": "text",
      "order": 1,
      "label": {
        "fr": "Responsable du traitement",
        "en": "Data controller",
        "it": "Titolare del trattamento"
      }
    },
    {
      "code": "sous_traitants",
      "target": "analysis",
      "type": "textarea",
      "order": 2,
      "label": {
        "fr": "Sous-traitants",
        "en": "Processors",
        "it": "Responsabili del trattamento"
      },
      "description": {
        "fr": "Sous-traitants au sens de l'article 28 du RGPD (ou équivalent), et objet de leur intervention.",
        "en": "Processors within the meaning of Article 28 GDPR (or equivalent), and the purpose of their involvement.",
        "it": "Responsabili del trattamento ai sensi dell'articolo 28 GDPR (o equivalente), e oggetto del loro intervento."
      }
    },
    {
      "code": "referentiels",
      "target": "analysis",
      "type": "textarea",
      "order": 3,
      "label": {
        "fr": "Référentiels applicables",
        "en": "Applicable frameworks",
        "it": "Riferimenti applicabili"
      }
    },
    {
      "code": "avis_dpo",
      "target": "analysis",
      "type": "textarea",
      "order": 4,
      "label": {
        "fr": "Avis du DPO",
        "en": "DPO opinion",
        "it": "Parere del DPO"
