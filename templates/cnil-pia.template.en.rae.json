    },
    {
      "code": "mesures_existantes",
      "target": "analysis",
      "type": "textarea",
      "order": 5,
      "label": {
        "fr": "Mesures existantes",
        "en": "Existing measures",
        "it": "Misure esistenti"
      },
      "description": {
        "fr": "Catalogue des mesures déjà en place, tenues hors du registre des mesures (réservé aux actions du plan d'action).",
        "en": "Catalogue of measures already in place, kept out of the measures register (reserved for action-plan items).",
        "it": "Catalogo delle misure già in atto, tenute fuori dal registro delle misure (riservato alle azioni del piano d'azione)."
      }
    },
    {
      "code": "evenement_redoute",
      "target": "risk",
      "type": "select",
      "order": 1,
      "required": true,
      "filterable": true,
      "label": {
        "fr": "Événement redouté",
        "en": "Feared event",
        "it": "Evento temuto"
      },
