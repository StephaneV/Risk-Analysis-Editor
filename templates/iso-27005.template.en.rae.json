{
  "format": "risk-analysis-editor",
  "version": "1.0",
  "metadata": {
    "title": "ISO/IEC 27005 template",
    "description": "Risk assessment skeleton following **ISO/IEC 27005**. Five-level likelihood × impact grid (score = product), with custom fields oriented towards assets, threats and vulnerabilities.\n\nTo complete: scope and acceptance criteria, identification of assets, threats and vulnerabilities, risk estimation then evaluation, and choice of treatment options.",
    "author": "",
    "organization": "",
    "scope": "",
    "methodology_reference": "ISO/IEC 27005 — Information security risk management",
    "revision": "1.0",
    "status": "draft",
    "language": "en",
    "kind": "template"
  },
  "grid": {
    "vertical_axis": {
      "label": "Likelihood",
      "description": "Probability that the risk scenario occurs.",
      "levels": [
        {
          "value": 1,
          "label": "Very low",
          "description": "Very unlikely to occur within the period."
        },
        {
          "value": 2,
          "label": "Low",
          "description": "Unlikely to occur."
        },
        {
          "value": 3,
          "label": "Medium",
          "description": "Plausible occurrence."
        },
        {
          "value": 4,
          "label": "High",
          "description": "Likely occurrence."
        },
        {
          "value": 5,
          "label": "Very high",
          "description": "Almost certain occurrence."
        }
      ]
    },
    "horizontal_axis": {
      "label": "Impact",
      "description": "Consequences for the organisation if it occurs.",
      "levels": [
        {
          "value": 1,
          "label": "Negligible",
          "description": "Insignificant consequences for the organisation."
        },
        {
          "value": 2,
          "label": "Low",
          "description": "Minor consequences, absorbed without difficulty."
        },
        {
          "value": 3,
          "label": "Medium",
          "description": "Notable but manageable consequences."
        },
        {
          "value": 4,
          "label": "Significant",
          "description": "Serious consequences, hard to reverse."
        },
        {
          "value": 5,
          "label": "Critical",
          "description": "Major consequences, threatening operations."
        }
      ]
    },
    "score": {
      "method": "product"
    },
    "criticality_levels": [
      {
        "code": "faible",
        "label": "Low",
        "score_min": 1,
        "score_max": 4,
        "color": "#2e9e5b",
        "acceptance": "acceptable",
        "order": 1,
        "description": "Low risk: acceptable, to be monitored."
      },
      {
        "code": "moyen",
        "label": "Medium",
        "score_min": 5,
        "score_max": 10,
        "color": "#e0b93a",
        "acceptance": "tolerable",
        "order": 2,
        "description": "Medium risk: tolerable under conditions; reduction to consider."
      },
      {
        "code": "eleve",
        "label": "High",
        "score_min": 11,
        "score_max": 16,
        "color": "#e6862e",
        "acceptance": "to_treat",
        "order": 3,
        "description": "High risk: treatment expected."
      },
      {
        "code": "critique",
        "label": "Critical",
        "score_min": 17,
        "score_max": 25,
        "color": "#d64545",
        "acceptance": "unacceptable",
        "order": 4,
        "description": "Critical risk: unacceptable as is; priority treatment."
      }
    ]
  },
  "custom_fields": [
