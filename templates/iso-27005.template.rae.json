{
  "format": "risk-analysis-editor",
  "version": "1.0",
  "metadata": {
    "author": "",
    "organization": "",
    "scope": "",
    "revision": "1.0",
    "status": "draft",
    "language": "fr",
    "kind": "template",
    "title": "Modèle ISO/IEC 27005",
    "description": "Squelette d'appréciation du risque selon **ISO/IEC 27005**. Grille vraisemblance × impact sur cinq niveaux (score = produit), et champs personnalisés orientés actifs, menaces et vulnérabilités.\n\nÀ compléter : périmètre et critères d'acceptation, identification des actifs, des menaces et vulnérabilités, estimation puis évaluation du risque, et choix des options de traitement.",
    "methodology_reference": "ISO/IEC 27005 — Gestion des risques liés à la sécurité de l'information"
  },
  "grid": {
    "vertical_axis": {
      "label": "Vraisemblance",
      "description": "Probabilité de réalisation du scénario de risque.",
      "levels": [
        {
          "value": 1,
          "label": "Très faible",
          "description": "Réalisation très improbable dans la période considérée."
        },
        {
          "value": 2,
          "label": "Faible",
          "description": "Réalisation peu probable."
        },
        {
          "value": 3,
          "label": "Moyenne",
          "description": "Réalisation plausible."
        },
        {
          "value": 4,
          "label": "Élevée",
          "description": "Réalisation probable."
        },
        {
          "value": 5,
          "label": "Très élevée",
          "description": "Réalisation quasi certaine."
        }
      ]
    },
    "horizontal_axis": {
      "label": "Impact",
      "description": "Conséquences pour l'organisation en cas de réalisation.",
      "levels": [
        {
          "value": 1,
          "label": "Négligeable",
          "description": "Conséquences insignifiantes pour l'organisation."
        },
        {
          "value": 2,
          "label": "Faible",
          "description": "Conséquences mineures, absorbées sans difficulté."
        },
        {
          "value": 3,
          "label": "Moyen",
          "description": "Conséquences notables mais maîtrisables."
        },
        {
          "value": 4,
          "label": "Important",
          "description": "Conséquences sérieuses, difficilement réversibles."
        },
        {
          "value": 5,
          "label": "Critique",
          "description": "Conséquences majeures, mettant en cause l'activité."
        }
      ]
    },
    "score": {
      "method": "product"
    },
    "criticality_levels": [
      {
        "code": "faible",
        "label": "Faible",
        "score_min": 1,
        "score_max": 4,
        "color": "#2e9e5b",
        "acceptance": "acceptable",
        "order": 1,
        "description": "Risque faible : acceptable, à surveiller."
      },
      {
        "code": "moyen",
        "label": "Moyen",
        "score_min": 5,
        "score_max": 10,
        "color": "#e0b93a",
        "acceptance": "tolerable",
        "order": 2,
        "description": "Risque moyen : tolérable sous conditions ; réduction à envisager."
      },
      {
        "code": "eleve",
        "label": "Élevé",
        "score_min": 11,
        "score_max": 16,
        "color": "#e6862e",
        "acceptance": "to_treat",
        "order": 3,
        "description": "Risque élevé : traitement attendu."
      },
      {
        "code": "critique",
        "label": "Critique",
        "score_min": 17,
        "score_max": 25,
        "color": "#d64545",
        "acceptance": "unacceptable",
        "order": 4,
        "description": "Risque critique : inacceptable en l'état ; traitement prioritaire."
      }
    ]
  },
