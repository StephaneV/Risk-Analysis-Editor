  "grid": {
    "vertical_axis": {
      "label": "Probability",
      "levels": [
        {
          "value": 1,
          "label": "Very low",
          "description": "Very low likelihood: highly improbable event, not expected to occur (order of magnitude: less than once every 10 years)."
        },
        {
          "value": 2,
          "label": "Low",
          "description": "Low likelihood: unlikely event, may occur exceptionally (order of magnitude: about once every 5 years)."
        },
        {
          "value": 3,
          "label": "Medium",
          "description": "Medium likelihood: possible event, may occur occasionally (order of magnitude: about once a year)."
        },
        {
          "value": 4,
          "label": "High",
          "description": "High likelihood: probable event, may occur regularly (order of magnitude: several times a year)."
        },
        {
          "value": 5,
          "label": "Very high",
          "description": "Very high likelihood: near-certain event, occurring frequently or recurrently."
        }
      ]
    },
    "horizontal_axis": {
      "label": "Severity",
      "levels": [
        {
          "value": 1,
          "label": "Very low",
          "description": "Very low impact: negligible consequence, no notable effect on activity, assets or compliance."
        },
        {
          "value": 2,
          "label": "Low",
          "description": "Low impact: minor consequences, limited and easily absorbed (slight operational inconvenience)."
        },
        {
          "value": 3,
          "label": "Medium",
          "description": "Medium impact: notable but manageable consequences (temporary disruption of activity, contained costs)."
        },
        {
          "value": 4,
          "label": "High",
          "description": "High impact: severe consequences on activity, finances or compliance, hardly reversible."
        },
        {
          "value": 5,
          "label": "Very high",
          "description": "Very high impact: critical, even irreversible consequences (business interruption, major harm to people or data, sanction)."
        }
      ]
    },
    "score": {
      "method": "product"
    },
    "criticality_levels": [
      {
        "code": "faible",
        "label": "Low",
        "score_min": 1,
        "score_max": 4,
        "color": "#2e9e5b",
        "acceptance": "acceptable",
        "order": 1,
        "description": "Acceptable risk: consistent with the risk acceptance criteria. No additional measure needed; monitor during reviews."
      },
      {
        "code": "modere",
        "label": "Moderate",
        "score_min": 5,
        "score_max": 9,
        "color": "#e0b93a",
        "acceptance": "tolerable",
        "order": 2,
        "description": "Tolerable risk: acceptable under conditions. Reduction measures are recommended based on a cost/benefit analysis."
      },
      {
        "code": "eleve",
        "label": "High",
        "score_min": 10,
        "score_max": 15,
        "color": "#e6862e",
        "acceptance": "to_treat",
        "order": 3,
        "description": "High risk: must be treated. Reduction measures must be planned and tracked to bring the risk to an acceptable level."
      },
      {
        "code": "critique",
        "label": "Critical",
        "score_min": 16,
        "score_max": 25,
        "color": "#d64545",
        "acceptance": "unacceptable",
        "order": 4,
        "description": "Unacceptable risk: exceeds the acceptance criteria. Priority and immediate treatment required before any go-live or continuation of activity."
      }
    ]
  },
